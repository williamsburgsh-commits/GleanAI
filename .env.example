# ---------------------------------------------------------------------------
# GleanAI environment variables (shared reference)
# Copy the relevant block into bot/.env and web/.env.local and fill in values.
# NEVER commit real secrets. This file documents the keys only.
# ---------------------------------------------------------------------------

# --- Supabase (server-side; service role bypasses RLS) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Public (web client) values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=
# Bot @username without @ (e.g. GleanAIBot) — used to build invite links in the Mini App
TELEGRAM_BOT_USERNAME=
# Public URL of the web app the bot links users to (e.g. https://gleanai.vercel.app)
WEB_APP_URL=

# --- Alchemy (Solana RPC for on-chain verification) ---
# Create a Solana app at https://dashboard.alchemy.com and copy the API key.
ALCHEMY_API_KEY=
# mainnet-beta or devnet
SOLANA_CLUSTER=devnet
# Optional explicit RPC URL; if blank it's derived from key + cluster:
#   https://solana-devnet.g.alchemy.com/v2/<ALCHEMY_API_KEY>
ALCHEMY_RPC_URL=

# --- Phantom deeplink ---
# The base URL Phantom redirects back to after connect/sign
PHANTOM_REDIRECT_URL=

# --- Admin ---
# Comma-separated Telegram IDs allowed to access the admin dashboard (bot side)
ADMIN_TELEGRAM_IDS=
# Shared password gate for the web admin dashboard (/admin). Use a strong secret.
ADMIN_DASHBOARD_PASSWORD=
# Telegram Mini App: the web app needs the bot token (server-side) to verify
# initData signatures. Must equal TELEGRAM_BOT_TOKEN above.
# (set in web/.env.local as TELEGRAM_BOT_TOKEN)

# --- Merkle claims (SPL distributor) ---
# Devnet test mint until $GLEAN launches. Required to publish claim epochs.
CLAIM_MINT=
NEXT_PUBLIC_CLAIM_MINT=
# Deployed glean-distributor program id (see programs/README.md)
CLAIM_PROGRAM_ID=
NEXT_PUBLIC_CLAIM_PROGRAM_ID=
# floor(epoch_points * units) — default 1e6 = 1 token/point at 6 decimals
CLAIM_POINTS_TO_UNITS=1000000
# Authority pubkey that signs on-chain set_root (manual signing OK for v1)
CLAIM_AUTHORITY=
